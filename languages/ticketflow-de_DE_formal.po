# Plugin name
msgid "Ticketflow"
msgstr "Ticketflow"

# Activator
msgid "Ticketflow Client"
msgstr "Ticketflow Kunde"

msgid "Ticketflow Agent"
msgstr "Ticketflow Agent"

msgid "Ticketflow Admin"
msgstr "Ticketflow Admin"

msgid "Support Portal"
msgstr "Support-Portal"

# Admin page
msgid "Support ticket system for %s. Manage client tickets, track SLA, and collaborate with your team."
msgstr "Ticket-System für %s. Verwalten Sie Kundenanfragen, überwachen Sie SLA-Fristen und arbeiten Sie im Team zusammen."

msgid "Launch Dashboard"
msgstr "Dashboard öffnen"

msgid "View Client Portal"
msgstr "Kundenportal anzeigen"

msgid "Total Tickets"
msgstr "Tickets gesamt"

msgid "Open"
msgstr "Offen"

msgid "Unassigned"
msgstr "Nicht zugewiesen"

msgid "Getting Started"
msgstr "Erste Schritte"

msgid "Add clients via the Dashboard under %1$sClients%2$s, or create WordPress users with the %3$ssubscriber%4$s or %3$sticketflow_client%4$s role."
msgstr "Fügen Sie Kunden über das Dashboard unter %1$sKunden%2$s hinzu, oder erstellen Sie WordPress-Benutzer mit der Rolle %3$ssubscriber%4$s oder %3$sticketflow_client%4$s."

msgid "Clients log in through the %1$sClient Portal%2$s using a magic link sent to their email — no password needed."
msgstr "Kunden melden sich über das %1$sKundenportal%2$s mit einem Magic Link an, der per E-Mail gesendet wird — kein Passwort nötig."

msgid "Assign staff the %1$sticketflow_agent%2$s or %1$sticketflow_admin%2$s role in %3$sUsers &rarr; Edit User%4$s to give them dashboard access."
msgstr "Weisen Sie Mitarbeitern die Rolle %1$sticketflow_agent%2$s oder %1$sticketflow_admin%2$s unter %3$sBenutzer &rarr; Benutzer bearbeiten%4$s zu, um Dashboard-Zugang zu gewähren."

msgid "Configure categories, SLA deadlines, email settings, and branding in %1$sDashboard &rarr; Settings%2$s."
msgstr "Konfigurieren Sie Kategorien, SLA-Fristen, E-Mail-Einstellungen und Branding unter %1$sDashboard &rarr; Einstellungen%2$s."

msgid "Tickets flow through statuses: %1$sOpen%2$s &rarr; %1$sIn Progress%2$s &rarr; %1$sWaiting%2$s &rarr; %1$sResolved%2$s &rarr; %1$sClosed%2$s. Resolved tickets auto-close after the configured idle period."
msgstr "Tickets durchlaufen die Status: %1$sOffen%2$s &rarr; %1$sIn Bearbeitung%2$s &rarr; %1$sWartend%2$s &rarr; %1$sGelöst%2$s &rarr; %1$sGeschlossen%2$s. Gelöste Tickets werden nach der konfigurierten Ruhezeit automatisch geschlossen."

# Email templates — ticket-created
msgid "Your Ticket Has Been Created"
msgstr "Ihr Ticket wurde erstellt"

msgid "Hi %s,"
msgstr "Hallo %s,"

msgid "We've received your support request and a member of our team will be in touch soon."
msgstr "Wir haben Ihre Supportanfrage erhalten und ein Mitglied unseres Teams wird sich in Kürze bei Ihnen melden."

msgid "Ticket"
msgstr "Ticket"

msgid "View in Portal"
msgstr "Im Portal anzeigen"

# Email templates — reply-added
msgid "New Reply on Your Ticket"
msgstr "Neue Antwort auf Ihr Ticket"

msgid "%s replied to ticket %s:"
msgstr "%s hat auf Ticket %s geantwortet:"

msgid "View Full Thread"
msgstr "Gesamten Verlauf anzeigen"

# Email templates — magic-link
msgid "Your Login Link"
msgstr "Ihr Login-Link"

msgid "Click the button below to log in to your support portal. This link expires in 15 minutes."
msgstr "Klicken Sie auf den Button, um sich in Ihrem Support-Portal anzumelden. Dieser Link ist 15 Minuten gültig."

msgid "Log In to Portal"
msgstr "Im Portal anmelden"

msgid "If the button doesn't work, copy and paste this URL into your browser:"
msgstr "Falls der Button nicht funktioniert, kopieren Sie diese URL in Ihren Browser:"

msgid "If you did not request this link, you can safely ignore this email."
msgstr "Falls Sie diesen Link nicht angefordert haben, können Sie diese E-Mail ignorieren."

# Email templates — status-changed
msgid "Ticket Status Updated"
msgstr "Ticket-Status aktualisiert"

msgid "The status of ticket %s has been updated."
msgstr "Der Status von Ticket %s wurde aktualisiert."

# Email templates — ticket-assigned
msgid "Ticket Assigned to You"
msgstr "Ticket Ihnen zugewiesen"

msgid "A ticket has been assigned to you."
msgstr "Ihnen wurde ein Ticket zugewiesen."

msgid "Ticket Details"
msgstr "Ticket-Details"

msgid "Client: %s"
msgstr "Kunde: %s"

msgid "View Ticket"
msgstr "Ticket anzeigen"

# Email templates — ticket-closed
msgid "Ticket Closed"
msgstr "Ticket geschlossen"

msgid "Ticket %s has been closed."
msgstr "Ticket %s wurde geschlossen."

msgid "Closed"
msgstr "Geschlossen"

msgid "If you need further assistance, you can reopen this ticket from the portal."
msgstr "Wenn Sie weitere Hilfe benötigen, können Sie dieses Ticket im Portal erneut öffnen."

