msgstr "[%s] Ticket geschlossen: %s"

# Email layout
msgid "All rights reserved."
msgstr "Alle Rechte vorbehalten."

# AttachmentService
msgid "File upload failed."
msgstr "Datei-Upload fehlgeschlagen."

msgid "File type not allowed."
msgstr "Dateityp nicht erlaubt."

msgid "File exceeds maximum size."
msgstr "Datei überschreitet die maximale Größe."

msgid "Failed to save file."
msgstr "Datei konnte nicht gespeichert werden."

msgid "Failed to record attachment."
msgstr "Anhang konnte nicht gespeichert werden."

# TicketService
msgid "Field \"%s\" is required."
msgstr "Das Feld \"%s\" ist erforderlich."

msgid "Failed to create ticket."
msgstr "Ticket konnte nicht erstellt werden."

msgid "Ticket not found."
msgstr "Ticket nicht gefunden."

msgid "Failed to update ticket."
msgstr "Ticket konnte nicht aktualisiert werden."

# AuthService
msgid "Invalid email address."
msgstr "Ungültige E-Mail-Adresse."

msgid "No account found with this email. Please contact support to get access."
msgstr "Kein Konto mit dieser E-Mail-Adresse gefunden. Bitte kontaktieren Sie den Support."

msgid "Too many requests. Please try again later."
msgstr "Zu viele Anfragen. Bitte versuchen Sie es später erneut."

msgid "Invalid or expired token."
msgstr "Ungültiger oder abgelaufener Token."

# API controllers
msgid "Authentication required."
msgstr "Authentifizierung erforderlich."

msgid "You do not have permission."
msgstr "Sie haben keine Berechtigung."

msgid "Email is required."
msgstr "E-Mail ist erforderlich."

msgid "A login link has been sent to your email. Check your inbox."
msgstr "Ein Login-Link wurde an Ihre E-Mail gesendet. Prüfen Sie Ihren Posteingang."

msgid "Token is required."
msgstr "Token ist erforderlich."

msgid "Not authenticated."
msgstr "Nicht authentifiziert."

msgid "Logged out."
msgstr "Abgemeldet."

msgid "Reply body is required."
msgstr "Antworttext ist erforderlich."

msgid "Failed to create reply."
msgstr "Antwort konnte nicht erstellt werden."

msgid "Reply not found."
msgstr "Antwort nicht gefunden."

msgid "Agent ID is required."
msgstr "Agent-ID ist erforderlich."

msgid "No file uploaded."
msgstr "Keine Datei hochgeladen."

msgid "Attachment not found."
msgstr "Anhang nicht gefunden."

msgid "File not found."
msgstr "Datei nicht gefunden."

msgid "Access denied."
msgstr "Zugriff verweigert."

msgid "Title and body are required."
msgstr "Titel und Text sind erforderlich."

msgid "Failed to create saved reply."
msgstr "Gespeicherte Antwort konnte nicht erstellt werden."

msgid "Saved reply not found."
msgstr "Gespeicherte Antwort nicht gefunden."

msgid "Client not found."
msgstr "Kunde nicht gefunden."

msgid "Valid email is required."
msgstr "Gültige E-Mail-Adresse ist erforderlich."

msgid "A user with this email already exists."
msgstr "Ein Benutzer mit dieser E-Mail-Adresse existiert bereits."

# Ticketflow.php
msgid "Ticketflow: The portal page is missing. Please deactivate and reactivate the plugin to recreate it."
msgstr "Ticketflow: Die Portal-Seite fehlt. Bitte deaktivieren und reaktivieren Sie das Plugin, um sie neu zu erstellen."

msgid "Ticketflow: Upload directory is not writable: %s"
msgstr "Ticketflow: Upload-Verzeichnis ist nicht beschreibbar: %s"
